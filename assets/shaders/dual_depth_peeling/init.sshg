name: init
stages:
  vertex:
    name: vertex
    path: default.vert
  fragment:
    name: fragment
    source: !glsl |
      #version 460
      
      layout(location = 0) out vec2 out_depth; // RG32F min max depth buffer
      
      void main() {
          float depth = gl_FragCoord.z;
          
          out_depth = vec2(1.f);
      }
