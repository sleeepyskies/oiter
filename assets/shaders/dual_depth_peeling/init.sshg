name: init
stages:
  vertex:
    name: vertex
    path: default.vert
  fragment:
    name: fragment
    source: !glsl |
      #version 460
      
      layout(location = 0) out vec2 out_depth;
      layout(location = 1) out vec4 out_front;
      layout(location = 2) out vec4 out_back;
      
      void main() {
        float depth = gl_FragCoord.z;
      
        out_depth.xy = vec2(-depth, depth);
      }
