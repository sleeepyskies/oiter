name: blend
stages:
  vertex:
    name: vertex
    source: |
      #version 460
      
      layout(location = 0) in vec4 a_position;
      
      void main() {
          gl_Position = a_position;
      }
  fragment:
    name: fragment
    source: |
      #version 460
      
      layout(location = 0) out vec4 FragColor;

      void main() {
          FragColor = vec4(1);
      }
